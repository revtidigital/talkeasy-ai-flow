{
  "routes": [
    { "handle": "filesystem" },

    {
      "src": "/(.*\\.(ico|png|jpg|jpeg|svg|css|js|woff|woff2))",
      "dest": "/$1"
    },

    {
      "src": "/faq",
      "status": 410
    },
    {
      "src": "/faq_cat/(.*)",
      "status": 410
    },
    {
      "src": "/(.*)/page/(.*)",
      "status": 410
    },
    {
      "src": "/product/theconverseai.com/(.*)",
      "status": 410
    },

    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}